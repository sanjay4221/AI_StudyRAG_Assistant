# StudyRAG — .gitignore

# ── Secrets (NEVER commit these)
.env
*.env
!.env.example

# ── Database files
*.db-journal
*.db-wal
*.db-shm
*.db
*.db-journal
*.db-wal
*.db-shm
studyrag.db

# ── User data (privacy)
uploads/*
!uploads/.gitkeep
vectorstore/*
!vectorstore/.gitkeep
vectorstore/

# ── Logs 
logs/*.log
!logs/.gitkeep

# ── Python 
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Virtual environments 
.venv/
venv/
env/
ENV/

# ── Testing 
.pytest_cache/
.coverage
htmlcov/
*.coveragerc

# ── IDEs 
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Docker 
*.vhdx

# ── HuggingFace model cache 
.cache/
uploads/user_*

uploads/user_*/
